# ========================================
# 🛠 ФАЙЛ КОНФИГУРАЦИИ ДЛЯ МОДУЛЯ api
# 
# ВНИМАНИЕ: Никогда не сохраняйте этот файл в репозитории с реальными значениями!
# Переименуйте в api.env
# Пример: api.env.example → api.env
# ========================================


# URL К БАЗЕ ДАННЫХ (ОБЯЗАТЕЛЬНО)
# Используется асинхронным ORM (например, SQLAlchemy + asyncpg).
# Должен начинаться с `postgresql+asyncpg://`.
# Пример: postgresql+asyncpg://пользователь:пароль@хост:порт/база
DATABASE_URL=postgresql+asyncpg://admin:admin@manga-postgres:5432/manga_day


# URL К БАЗЕ ДАННЫХ ДЛЯ ALEMBIC (ОБЯЗАТЕЛЬНО)
# Используется инструментом миграций Alembic.
# Должен начинаться с `postgresql://` (синхронное соединение).
# Обычно совпадает с DATABASE_URL, но без префикса asyncpg.
# Пример: postgresql://пользователь:пароль@хост:порт/база
SQLALCHEMY_URL=postgresql://admin:admin@manga-postgres:5432/manga_day


# ПУТЬ К КОНФИГУРАЦИОННОМУ ФАЙЛУ (ОБЯЗАТЕЛЬНО)
# Указывает путь к YAML-файлу с дополнительными настройками приложения.
# Должен быть доступен внутри контейнера или среды выполнения.
# Пример: config.yaml или /app/config/config.yaml
CONFIG_FILE=config.yaml